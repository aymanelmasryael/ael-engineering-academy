{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ael-quiz-schema",
  "title": "AEL Quiz",
  "description": "Weekly quiz — assessment of learned concepts",
  "type": "object",
  "required": ["id", "weekId", "moduleId", "questionCount", "timeLimit", "passingScore"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^QZ-\\d{2}$",
      "description": "Unique quiz identifier"
    },
    "weekId": {
      "type": "string",
      "pattern": "^WK-\\d{2}$"
    },
    "moduleId": {
      "type": "string",
      "pattern": "^MOD-[A-Z0-9-]+$"
    },
    "questionCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    },
    "timeLimit": {
      "type": "string",
      "description": "Time limit (e.g., '30 minutes')"
    },
    "passingScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "questionPool": {
      "type": "array",
      "items": { "type": "string", "pattern": "^Q-[A-Z0-9-]+-\\d{3}$" },
      "description": "Question IDs to draw from"
    },
    "concepts": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CON-[A-Z0-9-]+$" },
      "description": "Concepts covered by this quiz"
    }
  }
}
