{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ael-interview-schema",
  "title": "AEL Interview Question",
  "description": "Interview preparation question",
  "type": "object",
  "required": ["id", "weekId", "moduleId", "question", "expectedAnswer", "difficulty"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^INT-[A-Z0-9-]+-\\d{2}$",
      "description": "Unique interview question identifier"
    },
    "weekId": {
      "type": "string",
      "pattern": "^WK-\\d{2}$"
    },
    "moduleId": {
      "type": "string",
      "pattern": "^MOD-[A-Z0-9-]+$"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "expectedAnswer": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "concepts": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CON-[A-Z0-9-]+$" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "followUpQuestions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Potential follow-up questions"
    }
  }
}
