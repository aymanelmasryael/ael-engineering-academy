{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ael-course-schema",
  "title": "AEL Course",
  "description": "Top-level learning course entity",
  "type": "object",
  "required": ["id", "name", "description", "author", "version", "modules"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CRSE-[A-Z0-9-]+$",
      "description": "Unique course identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "author": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "license": {
      "type": "string"
    },
    "readingTime": {
      "type": "string"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^MOD-[A-Z0-9-]+$"
      },
      "minItems": 1,
      "description": "Array of module IDs in order"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "review", "published", "archived"] }
      }
    }
  }
}
