{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ael-project-schema",
  "title": "AEL Project",
  "description": "Module or course-level project",
  "type": "object",
  "required": ["id", "title", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^PRJ-[A-Z0-9-]+-\\d{2}$",
      "description": "Unique project identifier"
    },
    "weekId": {
      "type": "string",
      "pattern": "^WK-\\d{2}$"
    },
    "moduleId": {
      "type": "string",
      "pattern": "^MOD-[A-Z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["mini", "module", "capstone"],
      "description": "Project scope"
    },
    "requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expectedTime": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": ["intermediate", "advanced", "expert"]
    },
    "concepts": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CON-[A-Z0-9-]+$" }
    },
    "challenges": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CH-[A-Z0-9-]+-\\d{2}$" },
      "description": "Challenges that feed into this project"
    },
    "deliverables": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evaluationCriteria": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
