{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ael-challenge-schema",
  "title": "AEL Challenge",
  "description": "Capstone challenge — comprehensive project per week",
  "type": "object",
  "required": ["id", "weekId", "moduleId", "title", "description", "requirements"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CH-[A-Z0-9-]+-\\d{2}$",
      "description": "Unique challenge identifier"
    },
    "weekId": {
      "type": "string",
      "pattern": "^WK-\\d{2}$"
    },
    "moduleId": {
      "type": "string",
      "pattern": "^MOD-[A-Z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "requirements": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "expectedTime": {
      "type": "string"
    },
    "difficulty": {
      "type": "string",
      "enum": ["intermediate", "advanced", "expert"]
    },
    "learningOutcomes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^LO-[A-Z0-9-]+$" }
    },
    "concepts": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CON-[A-Z0-9-]+$" }
    },
    "exercises": {
      "type": "array",
      "items": { "type": "string", "pattern": "^EX-[A-Z0-9-]+-\\d{2}$" },
      "description": "Prerequisite exercises"
    },
    "evaluationCriteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "How this challenge is evaluated"
    }
  }
}
